{
  "uid": "w_app",
  "type": "app",
  "config": {
    "description": "An example to demonstrate how to build a private oauth app with developer projects.",
    "name": "w-App",
    "distribution": "private",
    "auth": {
      "type": "oauth",
      "redirectUrls": [
        "http://localhost:3000/api/hubspot/oauth/callback",
        "https://localhost:3000/api/hubspot/oauth/callback"
      ],
      "requiredScopes": [
        "oauth",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "crm.schemas.contacts.read"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": ["https://api.hubapi.com"],
      "iframe": [],
      "img": []
    },
    "support": {
      "supportEmail": "support@example.com",
      "documentationUrl": "https://example.com/docs",
      "supportUrl": "https://example.com/support",
      "supportPhone": "+18005555555"
    }
  }
}
