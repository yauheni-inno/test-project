# Wix Self-Hosted App - HubSpot Integration
# Copy this file to .env.local and fill in your values

# HubSpot OAuth (required for connect flow)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=https://your-domain.com/api/hubspot/oauth/callback

# Optional: verify HubSpot webhook signatures
# HUBSPOT_WEBHOOK_SECRET=your-hubspot-webhook-secret

# Wix app backend auth (used for AppStrategy + webhook verification)
WIX_CLIENT_ID=your-wix-app-id
WIX_CLIENT_SECRET=your-wix-app-secret
WIX_APP_JWT_KEY=your-wix-app-public-jwt-key

# Next.js Configuration
NEXT_PUBLIC_WIX_CLIENT_ID=your-wix-client-id
